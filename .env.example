# ============================================================================
#  The ONLY file you need to edit. Copy it to .env and fill in the blanks:
#      cp .env.example .env
# ============================================================================

# --- Snowflake (key-pair auth) ---------------------------------------------
# Account identifier, e.g. xy12345.eu-central-1
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=DBT_USER
SNOWFLAKE_ROLE=DBT_ROLE
SNOWFLAKE_WAREHOUSE=DBT_WH
SNOWFLAKE_DATABASE=NYC_CITI_BIKE
SNOWFLAKE_SCHEMA=PUBLIC
# Path INSIDE the container (./secrets is mounted read-only there). Used ONLY by
# ad-hoc CLI dbt (`make dbt`); the dbt_transform DAG takes creds from the Airflow
# connection (inline PEM below) instead.
SNOWFLAKE_PRIVATE_KEY_PATH=/usr/local/airflow/secrets/dbt_user.p8
# Inline PEM for the AIRFLOW connection (key-pair, mirrors the VPS). One line,
# UNENCRYPTED key, real newlines written as \n. Generate it from your key file
# (no manual escaping) with:
#   python3 -c "import json;print('SNOWFLAKE_PRIVATE_KEY_CONTENT='+json.dumps(open('secrets/dbt_user.p8').read())[1:-1])" >> .env
SNOWFLAKE_PRIVATE_KEY_CONTENT=

# --- OpenWeather -----------------------------------------------------------
OPENWEATHER_API_KEY=

# --- Airflow UI (http://localhost:8080) ------------------------------------
# Dev mode is login-free (SimpleAuthManager, all users are admin). Nothing to set.

# --- Host user id (Linux: set to `id -u`; macOS/Windows: leave as is) -------
AIRFLOW_UID=50000
